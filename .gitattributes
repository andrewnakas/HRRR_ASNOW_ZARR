# Git LFS configuration for zarr data files

# Track all zarr chunk files with Git LFS
data/**/* filter=lfs diff=lfs merge=lfs -text
*.zarr/**/* filter=lfs diff=lfs merge=lfs -text

# Specifically track common zarr file patterns
**/.zarray filter=lfs diff=lfs merge=lfs -text
**/[0-9]* filter=lfs diff=lfs merge=lfs -text
**/[0-9]*.[0-9]* filter=lfs diff=lfs merge=lfs -text
**/[0-9]*.[0-9]*.[0-9]* filter=lfs diff=lfs merge=lfs -text

# Don't track metadata files with LFS (they're small text files)
**/.zgroup !filter !diff !merge text
**/.zattrs !filter !diff !merge text
**/.zmetadata !filter !diff !merge text
